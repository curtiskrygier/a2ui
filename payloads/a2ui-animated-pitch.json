            },
            {
              "blocks": [{
                "type": "animated_border",
                "from": "#10b981",
                "to": "#6366f1",
                "via": "#34d399",
                "speed": "4",
                "content": "**② Schema**\n\nGet back valid JSON. Typed atoms. Verifiable before it ever renders."
              }]
            },
            {
              "blocks": [{
                "type": "animated_border",
                "from": "#f59e0b",
                "to": "#10b981",
                "via": "#fbbf24",
                "speed": "4",
                "content": "**③ App**\n\nPaste. Click Open. Live URL. Works in any Google Workspace surface."
              }]
            }
          ]
        }
      ]
    },
    {
      "type": "wave_divider",
      "color": "#10b981",
      "height": 40,
      "opacity": "0.12",
