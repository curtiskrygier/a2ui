function _renderTogafPage() {
  var payload = {"title": "TOGAF\u00ae 10 \u2014 Foundation & Practitioner", "theme": "light", "blocks": [{"type": "hub", "subjects": [{"id": "apercu", "label": "\ud83c\udfdb\ufe0f TOGAF\u00ae 10", "color": "#6366f1", "slides": [{"id": "overview", "label": "\ud83d\udccb Overview", "blocks": [{"type": "domain_brief", "title": "TOGAF\u00ae 10", "badge": "Foundation & Practitioner", "description": "The Open Group Architecture Framework \u2014 the world's most widely adopted enterprise architecture standard. Two-part certification: Foundation (Part 1) and Practitioner (Part 2).", "image_url": "data:image/jpeg;base64,", "accent": "#6366f1", "key_facts": [{"label": "Part 1", "value": "40 MCQ \u00b7 60 min \u00b7 55% pass"}, {"label": "Part 2", "value": "8 scenarios \u00b7 90 min \u00b7 60% pass"}, {"label": "Part 2", "value": "Open book (standard only)"}, {"label": "Publisher", "value": "The Open Group"}], "areas": [{"label": "ADM Cycle", "color": "#6366f1"}, {"label": "Implementation", "color": "#0ea5e9"}, {"label": "EA Concepts", "color": "#3b82f6"}, {"label": "Stakeholders", "color": "#10b981"}, {"label": "Phase A", "color": "#f59e0b"}, {"label": "Frameworks", "color": "#8b5cf6"}]}, {"type": "catalogue_provenance", "label": "Assembled from", "sources": [{"icon": "\ud83d\udcda", "what": "Curriculum content", "catalogue": "a2knowledge", "note": "TOGAF\u00ae 10 Standard \u2014 The Open Group", "color": "#10b981", "target": "Curriculum facts & domains"}, {"icon": "\ud83d\uddbc\ufe0f", "what": "Cover image", "catalogue": "a2media", "note": "Vocab-keyed, Gemini Imagen \u2014 lookup-before-generate pattern", "color": "#8b5cf6", "target": "Cover image"}, {"icon": "\ud83c\udfa8", "what": "UI atoms", "catalogue": "a2UI", "note": "domain_brief, hub, flashcard_deck, steps, knowledge_check", "color": "#6366f1", "target": "UI atoms & layout"}]}, {"type": "cert_disclaimer", "cert": "TOGAF\u00ae", "holder": "The Open Group", "url": "https://www.opengroup.org/togaf"}]}]}, {"id": "adm", "label": "\ud83d\udd04 ADM Phases", "color": "#6366f1", "slides": [{"id": "epreuve", "label": "\ud83d\udccb Exam", "blocks": [{"type": "dark_hero", "heading": "TOGAF\u00ae 10 \u2014 Two-Part Exam", "subtext": "Part 1 Foundation: 40 MCQ \u00b7 60 min \u00b7 55% pass \u00b7 Closed book   |   Part 2 Practitioner: 8 scenarios \u00b7 90 min \u00b7 60% pass \u00b7 Open book (standard only)", "badge": "The Open Group", "align": "center"}, {"type": "key_takeaways", "points": ["**Part 1** tests recall and comprehension \u2014 closed book, 40 multiple-choice questions", "**Part 2** tests application and analysis \u2014 open book, 8 complex scenario questions with multiple responses", "Open book means the TOGAF standard only \u2014 not notes, not the delegate pack", "Part 2 questions present a scenario first, then ask you to select the best architectural response", "Domains weighted by exam frequency: ADM Core (25%) \u00b7 Implementation (20%) \u00b7 EA Concepts (15%)"]}]}, {"id": "adm-cycle", "label": "\ud83d\udd04 ADM Cycle", "blocks": [{"type": "dark_hero", "heading": "The ADM \u2014 A Continuous Cycle", "subtext": "Preliminary + Phases A through H \u00b7 Requirements Management permanently at the centre \u00b7 each phase feeds the next", "badge": "Core pillar \u00b7 Foundation + Practitioner", "align": "center"}, {"type": "steps", "items": [{"label": "Preliminary", "text": "Prepare the enterprise: establish EA capability, tailor TOGAF, define Architecture Principles, set up governance \u2014 before the first architecture cycle begins"}, {"label": "A \u2014 Vision", "text": "Agree scope and high-level target; produce Statement of Architecture Work; secure approval to proceed"}, {"label": "B \u2014 Business", "text": "Develop Target Business Architecture; identify business gaps; produce Business Architecture components of the Roadmap"}, {"label": "C \u2014 IS", "text": "Develop Target Data Architecture and Target Application Architecture (two sub-phases); choose data-driven or application-driven sequence"}, {"label": "D \u2014 Technology", "text": "Develop Target Technology Architecture; inherit and embed security controls from Phases B and C"}, {"label": "E \u2014 Opportunities", "text": "Produce first complete Architecture Roadmap; identify Transition Architectures; generate work packages with Mainstream/Contain/Replace classifications"}, {"label": "F \u2014 Migration", "text": "Finalize Implementation and Migration Plan; assign business value to each work package; prioritize projects by cost/benefit and risk"}, {"label": "G \u2014 Governance", "text": "Provide architectural oversight of implementation; issue Architecture Contracts; run compliance reviews; confirm Phase H handoff"}, {"label": "H \u2014 Change", "text": "Keep the architecture alive; monitor for triggers; manage change requests; initiate a new ADM cycle when a major change is identified"}, {"label": "\u21bb Requirements Mgmt", "text": "Runs continuously at the centre of the wheel \u2014 captures, stores, and feeds requirements to every phase; never a sequential phase"}]}, {"type": "knowledge_check", "question": "Requirements Management in the TOGAF ADM is best described as:", "options": ["A continuous process running in parallel with all phases, permanently at the centre of the wheel", "Phase I \u2014 executed after Phase H to capture lessons learned", "Part of Phase A only \u2014 requirements are set once and frozen", "An optional extension used only in Practitioner-level engagements"], "correct": 0, "explanation": "Requirements Management is NOT a sequential phase. It runs continuously at the centre of the ADM wheel, capturing and feeding requirements to every phase throughout the entire cycle."}]}, {"id": "preliminary", "label": "\u2699\ufe0f Preliminary", "blocks": [{"type": "dark_hero", "heading": "Preliminary Phase \u2014 Prepare the Enterprise", "subtext": "Executed BEFORE Phase A \u2014 establishes the EA capability itself: the team, the tools, the principles, the governance", "badge": "High weight \u00b7 Both levels", "align": "center"}, {"type": "steps", "items": [{"label": "1 \u00b7 Scope the Enterprise", "text": "Identify which organizations, business units, and geographies are within scope of the EA practice"}, {"label": "2 \u00b7 Confirm Governance", "text": "Secure executive sponsorship; establish the Architecture Board; define the governance and decision-making framework"}, {"label": "3 \u00b7 Define the Team", "text": "Establish the EA practice: roles, responsibilities, skills, reporting structure, and relationship with the rest of the business"}, {"label": "4 \u00b7 Establish Principles", "text": "Define Architecture Principles \u2014 the rules and guidelines that govern all EA work: Business, Data, Application, and Technology principles"}, {"label": "5 \u00b7 Tailor TOGAF", "text": "Adapt the framework to the organizational context: which methods to use, which to skip, how to handle exceptions"}, {"label": "6 \u00b7 Implement Tools", "text": "Deploy the Architecture Repository and supporting modeling tools; load baseline content"}]}, {"type": "flashcard_deck", "accent": "#6366f1", "label_front": "OUTPUT", "label_back": "PURPOSE", "cards": [{"front": "Organisational Model for Enterprise Architecture", "back": "Defines the EA team structure, roles, responsibilities, and how the EA practice relates to the rest of the business."}, {"front": "Tailored Architecture Framework", "back": "TOGAF adapted for the organization \u2014 which methods, modeling languages, content frameworks, and governance mechanisms apply."}, {"front": "Architecture Principles", "back": "The governing rules for all subsequent EA work across four domains: Business, Data, Application, and Technology."}, {"front": "Architecture Governance Framework", "back": "The decision-making and oversight structure \u2014 who approves what, how compliance is enforced, how exceptions are handled."}, {"front": "Initial Architecture Repository", "back": "Baseline content loaded into the repository, ready for the first architecture development cycle."}]}, {"type": "knowledge_check", "question": "An organisation is beginning its first TOGAF-based EA initiative. The CTO asks the lead architect to start developing the Architecture Vision. What should the architect do first?", "options": ["Complete the Preliminary Phase \u2014 establish governance, principles, and tailor TOGAF before starting Phase A", "Begin Phase A immediately \u2014 the Architecture Vision defines the scope of all subsequent work including governance", "Run Phase B first to establish the business baseline before attempting a vision", "The Preliminary Phase is optional \u2014 proceed directly to Phase A"], "correct": 0, "explanation": "The Preliminary Phase must be completed before Phase A begins. It establishes the EA capability itself \u2014 governance, principles, tailored framework \u2014 without which Phase A has no foundation to build on. A common exam trap is to treat Preliminary as optional or as part of Phase A."}]}, {"id": "per-phase", "label": "\ud83d\udcda Phase Guide", "blocks": [{"type": "dark_hero", "heading": "Per-Phase Purpose and Key Outputs", "subtext": "Foundation Part 1 tests recall of what each phase produces \u2014 know these precisely", "badge": "High weight \u00b7 Foundation", "align": "center"}, {"type": "flashcard_deck", "accent": "#6366f1", "label_front": "PHASE", "label_back": "PURPOSE + KEY OUTPUTS", "cards": [{"front": "Preliminary", "back": "PURPOSE: Prepare the enterprise for TOGAF-based EA\nOUTPUTS: Organisational Model \u00b7 Tailored Framework \u00b7 Architecture Principles \u00b7 Governance Framework \u00b7 Initial Repository"}, {"front": "Phase A \u2014 Architecture Vision", "back": "PURPOSE: Develop high-level aspirational vision; secure approval to proceed\nOUTPUTS: Statement of Architecture Work \u00b7 Architecture Vision \u00b7 Communications Plan \u00b7 Tailored Architecture Framework"}, {"front": "Phase B \u2014 Business Architecture", "back": "PURPOSE: Develop Target Business Architecture; identify business gaps\nOUTPUTS: Draft Architecture Definition Document (Business) \u00b7 Business Architecture Roadmap components \u00b7 Updated Statement of Architecture Work"}, {"front": "Phase C \u2014 Information Systems Architecture", "back": "PURPOSE: Develop Target Data and Application Architectures\nOUTPUTS: Draft Architecture Definition Document (IS) \u00b7 Data + Application Architecture Roadmap components \u00b7 Data and Application Principles"}, {"front": "Phase D \u2014 Technology Architecture", "back": "PURPOSE: Develop Target Technology Architecture (inherits security from B+C)\nOUTPUTS: Draft Architecture Definition Document (Technology) \u00b7 Technology Architecture Roadmap components \u00b7 Technology Principles"}, {"front": "Phase E \u2014 Opportunities & Solutions", "back": "PURPOSE: Generate first complete Architecture Roadmap; identify Transition Architectures and work packages\nOUTPUTS: Architecture Roadmap v1 \u00b7 Transition Architecture definitions \u00b7 Implementation and Migration Plan v0.1"}, {"front": "Phase F \u2014 Migration Planning", "back": "PURPOSE: Finalize Implementation and Migration Plan with priorities and business value\nOUTPUTS: Implementation and Migration Plan (final) \u00b7 Finalized Architecture Roadmap \u00b7 Architecture Completion Assessment"}, {"front": "Phase G \u2014 Implementation Governance", "back": "PURPOSE: Architectural oversight of implementation\nOUTPUTS: Architecture Contracts \u00b7 Compliance Assessments \u00b7 Change Requests \u00b7 Recommendations on project termination/continuation"}, {"front": "Phase H \u2014 Architecture Change Management", "back": "PURPOSE: Keep the architecture alive and responsive to change\nOUTPUTS: Architecture Updates \u00b7 Changes to Framework and Principles \u00b7 New Request for Architecture Work (if major change triggers new ADM cycle)"}, {"front": "Requirements Management", "back": "PURPOSE: Capture, store, and feed requirements to every phase continuously\nNOT A SEQUENTIAL PHASE \u2014 runs permanently at the centre of the ADM wheel alongside all phases"}]}]}, {"id": "adm-steps", "label": "\ud83d\udd01 B\u2013C\u2013D Steps", "blocks": [{"type": "dark_hero", "heading": "Common Steps \u2014 Phases B, C and D", "subtext": "The same 9-step procedure applies identically to Business, Information Systems, and Technology Architecture development", "badge": "High weight \u00b7 Foundation + Practitioner", "align": "center"}, {"type": "steps", "items": [{"label": "1 \u00b7 Select", "text": "Select reference models, viewpoints, and tools \u2014 leverage existing reference models to skip redundant work"}, {"label": "2 \u00b7 Baseline", "text": "Develop Baseline Architecture Description \u2014 document the existing state, limiting detail to areas affected by a gap"}, {"label": "3 \u00b7 Target", "text": "Develop Target Architecture Description \u2014 define the future state that addresses stakeholder requirements"}, {"label": "4 \u00b7 Gap", "text": "Perform Gap Analysis \u2014 compare Baseline and Target to establish exactly what is changing"}, {"label": "5 \u00b7 Roadmap", "text": "Define Candidate Roadmap Components \u2014 identify work packages, timeline blocks, and sequencing"}, {"label": "6 \u00b7 Impacts", "text": "Resolve Impacts Across the Architecture Landscape \u2014 analyze against concurrent projects and transition states"}, {"label": "7 \u00b7 Review", "text": "Conduct Formal Stakeholder Review \u2014 present trade-offs and scope of change to secure validation"}, {"label": "8 \u00b7 Finalize", "text": "Finalize the Architecture \u2014 ensure all domain sub-activities are cleanly closed and recorded"}, {"label": "9 \u00b7 Document", "text": "Create the Architecture Definition Document \u2014 package finalized models and criteria into formal deliverables"}]}]}, {"id": "adm-security", "label": "\ud83d\udd12 Security B\u2013C\u2013D", "blocks": [{"type": "dark_hero", "heading": "Security Considerations per Domain Phase", "subtext": "Each domain has a distinct security focus \u2014 the Technology phase inherits rather than creates", "badge": "Medium weight", "align": "center"}, {"type": "flashcard_deck", "accent": "#6366f1", "label_front": "PHASE", "label_back": "SECURITY FOCUS", "cards": [{"front": "Phase B \u2014 Business Architecture", "back": "Focuses on enterprise trust framework, overarching risk, and corporate control frameworks (ISO standards, COBIT). Fully independent of specific downstream IT or infrastructure systems."}, {"front": "Phase C \u2014 Information Systems", "back": "Focuses directly on functional security services and explicit security classifications applied to data assets and application logic components."}, {"front": "Phase D \u2014 Technology Architecture", "back": "Typically requires NO unique stand-alone security artifacts \u2014 it inherits and embeds the security controls defined in Phases B and C. Architect's duty: verify controls are represented effectively in the infrastructure design."}, {"front": "Phase C Sequencing \u2014 Data-Driven", "back": "Defines and structures data entities FIRST before application components. Recommended by traditional methodologies (Spewak's EAP). Ensures stable foundation resilient to application software changes."}, {"front": "Phase C Sequencing \u2014 Application-Driven", "back": "Focuses on major core application systems (ERP, CRM) as the primary entry point. Driven by off-the-shelf software procurement. Practical for rapid deployment but integration issues across legacy domains are a major challenge."}]}]}, {"id": "adm-io", "label": "\ud83d\udce5 Inputs & Outputs", "blocks": [{"type": "dark_hero", "heading": "Domain Architecture Inputs and Outputs", "subtext": "Applies to Phases B, C, and D \u2014 know what comes in and what must come out", "badge": "Medium weight", "align": "center"}, {"type": "flashcard_deck", "accent": "#6366f1", "label_front": "INPUT TYPE", "label_back": "WHAT IT INCLUDES", "cards": [{"front": "Non-Architectural Inputs", "back": "Request for Architecture Work \u00b7 Current Capability Assessment \u00b7 Communications Plan"}, {"front": "Architectural Inputs", "back": "Organisational Model for EA \u00b7 Tailored Architecture Framework \u00b7 Statement of Architecture Work \u00b7 Architecture Principles \u00b7 Enterprise Continuum \u00b7 Architecture Repository \u00b7 Architecture Vision (high-level)"}, {"front": "Core Outputs", "back": "Updated Architecture Vision deliverables \u00b7 Updated Statement of Architecture Work (if scope changed) \u00b7 Validated domain principles \u00b7 Draft Architecture Definition Document \u00b7 Draft Architecture Requirements Specification \u00b7 Domain components of the Architecture Roadmap"}]}]}]}, {"id": "impl", "label": "\ud83d\ude80 Implementation", "color": "#0ea5e9", "slides": [{"id": "approaches", "label": "\ud83c\udfd7\ufe0f Approaches", "blocks": [{"type": "dark_hero", "heading": "Deployment Approaches & Methodologies", "subtext": "Three deployment strategies and three core methodologies \u2014 know the distinctions", "badge": "High weight \u00b7 Foundation", "align": "center"}, {"type": "flashcard_deck", "accent": "#0ea5e9", "label_front": "APPROACH", "label_back": "DEFINITION", "cards": [{"front": "Greenfield", "back": "Setting up a completely new implementation environment from scratch, built entirely without legacy software constraints."}, {"front": "Revolutionary", "back": "Radical transition: old systems completely cut off at a precise milestone, new capabilities instantly brought live."}, {"front": "Evolutionary", "back": "Slow convergence via phased rollouts or parallel system running over a planned timeline to manage corporate absorption."}, {"front": "Quick Win methodology", "back": "Leverages snapshots for rapid delivery of visible value early in the migration."}, {"front": "Achievable Targets methodology", "back": "Focuses on mid-term milestones \u2014 delivers capability increments that are realistic within the planning horizon."}, {"front": "Value Chain methodology", "back": "Prioritizes work packages based on vertical value flows \u2014 start with what delivers the most business value end-to-end."}]}]}, {"id": "work-packages", "label": "\ud83d\udce6 Work Packages", "blocks": [{"type": "dark_hero", "heading": "Decomposing and Grouping Work Packages", "subtext": "Classify every legacy system as Mainstream, Contain, or Replace \u2014 then organize into portfolio groupings", "badge": "High weight \u00b7 Practitioner", "align": "center"}, {"type": "steps", "items": [{"label": "1 \u00b7 Consolidate Gaps", "text": "Aggregate all gap analysis results across Business, Data, Application, and Technology domains"}, {"label": "2 \u00b7 Apply Solutions", "text": "Populate the Solution column in the master matrix \u2014 new development, existing configuration, or new procurement"}, {"label": "3 \u00b7 Classify Legacy", "text": "Mainstream (retained) \u00b7 Contain (active but constrained within 3-year horizon) \u00b7 Replace (decommission within horizon)"}, {"label": "4 \u00b7 Decompose", "text": "Break high-level work packages into manageable steps mapping to discrete capability increments"}, {"label": "5 \u00b7 Organize Portfolios", "text": "Structure into coherent project groupings based on technical dependencies and the strategic migration path"}]}, {"type": "key_takeaways", "points": ["**Transition Architecture** = mandated when total change scope is too large for a single step", "Difficult/high-risk work should be deferred until simpler work packages have established core capability foundations", "Each Transition Architecture is a stable intermediate state where change can pause and deliver standalone value"]}]}, {"id": "phase-fg", "label": "\ud83d\udcc5 Phase F & G", "blocks": [{"type": "dark_hero", "heading": "Phase F Migration Planning \u00b7 Phase G Governance", "subtext": "F = plan and prioritize the migration \u00b7 G = govern the implementation", "badge": "High weight \u00b7 Practitioner", "align": "center"}, {"type": "steps", "items": [{"label": "F1 \u00b7 Management Alignment", "text": "Confirm the roadmap aligns with portfolio, program, and project management governance"}, {"label": "F2 \u00b7 Business Value", "text": "Assign a business value to each work package via 6 criteria: Performance, ROI, Business Value, CSFs, MOE, Strategic Fit"}, {"label": "F3 \u00b7 Resource Estimate", "text": "Estimate staffing, costs, and availability across the migration timeline"}, {"label": "F4 \u00b7 Prioritize", "text": "Cost/benefit assessment + comprehensive risk validation for each migration project"}, {"label": "F5 \u00b7 Confirm Roadmap", "text": "Update Architecture Definition Document to reflect project realities"}, {"label": "F6 \u00b7 Migration Plan", "text": "Document finalized project charters, milestones, and work breakdown structures"}, {"label": "F7 \u00b7 Lessons Learned", "text": "Capture operational knowledge from the cycle in the centralized repository"}]}, {"type": "steps", "items": [{"label": "G1 \u00b7 Scope", "text": "Confirm scope and priorities with development and operations management"}, {"label": "G2 \u00b7 Resources", "text": "Identify deployment resources and specialist skills needed"}, {"label": "G3 \u00b7 Guide", "text": "Provide architectural oversight to active development iterations"}, {"label": "G4 \u00b7 Compliance Reviews", "text": "Conduct formal Architecture Compliance Reviews against criteria"}, {"label": "G5 \u00b7 Implement", "text": "Transition the compliant solution into active business and IT operational environments"}, {"label": "G6 \u00b7 Post-Implementation", "text": "Verify benefit delivery and cleanly close the project"}]}, {"type": "knowledge_check", "question": "In Phase G, what is the difference between an Architecture Contract and an Architecture Requirements Specification?", "options": ["Contract = administrative tool directing the team toward an agreed future; ARS = technical tool setting strict bounds on what can be built", "Contract = technical specification of what to build; ARS = administrative sign-off document", "They are interchangeable \u2014 both govern implementation conformance", "The Contract is used in Phase F; the ARS is used in Phase G only"], "correct": 0, "explanation": "The Architecture Contract is administrative \u2014 it directs and controls the team toward an agreed future. The Architecture Requirements Specification is technical \u2014 it sets strict quantitative bounds on what the team can build. Both are mandatory in Phase G but serve completely different purposes."}]}, {"id": "comms", "label": "\ud83d\udce2 Communicating", "blocks": [{"type": "dark_hero", "heading": "Communicating with Solution Implementers", "subtext": "The anti-pattern is handing over diagrams without context \u2014 implementers need 4 explicit things", "badge": "High weight \u00b7 Practitioner", "align": "center"}, {"type": "key_takeaways", "points": ["**Anti-pattern**: bare modeling diagrams without operational context \u2014 implementers cannot deduce gaps or mandatory parameters from visuals alone", "**Context** \u2014 the project's place in the roadmap", "**Gaps** \u2014 differentiate gaps this project is responsible for vs adjacent gaps to ignore", "**Architecture Specifications** \u2014 exact criteria used for compliance", "**Controls** \u2014 exclusionary specifications (what is prohibited, not just what is permitted)", "Compliance test: the reasonable interpretation test \u2014 if a neutral person reading the spec would draw the same conclusion, it is clear enough"]}]}]}, {"id": "concepts", "label": "\ud83c\udfd7\ufe0f EA Concepts", "color": "#3b82f6", "slides": [{"id": "ea-purpose", "label": "\ud83c\udfaf Purpose", "blocks": [{"type": "dark_hero", "heading": "Foundational EA Concepts", "subtext": "Purpose, landscape characteristics, and the Four-Purpose Capability Model", "badge": "High weight \u00b7 Foundation", "align": "center"}, {"type": "flashcard_deck", "accent": "#3b82f6", "label_front": "CONCEPT", "label_back": "DEFINITION", "cards": [{"front": "Why develop an Enterprise Architecture?", "back": "One reason only: to guide effective change. EA provides a rigorous planning approach combined with a predictable change governance methodology."}, {"front": "EA Landscape \u2014 four dimensions", "back": "Breadth (subject matter) \u00b7 Depth (granularity) \u00b7 Time (horizon) \u00b7 Recency (accuracy/maintenance). Primary model purpose: analyze and understand complex systems. Secondary: re-use across the enterprise continuum."}, {"front": "Architecture Capability \u2014 definition", "back": "A formal business capability composed of organizational structures, defined roles, explicit responsibilities, skills, and processes \u2014 gives an enterprise the ability to develop, sustain, use, and govern architecture effectively."}, {"front": "4-Purpose Capability: Strategy", "back": "Long-term target architectures and roadmaps over 3\u201310 year planning horizon. Sets terms of reference and governance across multiple programs and portfolios."}, {"front": "4-Purpose Capability: Portfolio", "back": "Cross-functional, multi-phase change initiatives across a single portfolio. Identifies individual projects and aligns their approaches."}, {"front": "4-Purpose Capability: Project", "back": "Single project scope \u2014 clarifies value, addresses dependencies, and assures baseline compliance."}, {"front": "4-Purpose Capability: Solution Delivery", "back": "Maps directly to a single project or major component. Defines exactly how change will be designed and delivered while setting firm guardrails and controls."}]}]}, {"id": "governance", "label": "\u2696\ufe0f Governance", "blocks": [{"type": "dark_hero", "heading": "Governance Structure and Conformance Levels", "subtext": "Hierarchical governance + six levels of conformance \u2014 both high-weight exam topics", "badge": "High weight \u00b7 Both levels", "align": "center"}, {"type": "key_takeaways", "points": ["**Governance definition (ISO/IEC 38500:2015)**: a system that directs and controls a current and future state", "Hierarchy: Corporate \u2192 EA Governance \u2192 Business Architecture Governance \u2192 Domain Architecture Governance", "**Security and Risk Governance** sits as a cross-cutting intermediate layer intersecting all domain levels", "Architect's mandate: govern (1) the development of the Target Architecture AND (2) all downstream operational change within its scope"]}, {"type": "flashcard_deck", "accent": "#3b82f6", "label_front": "CONFORMANCE LEVEL", "label_back": "DEFINITION", "cards": [{"front": "Irrelevant", "back": "The solution has zero features in common with the specification \u2014 conformance doesn't arise."}, {"front": "Consistent", "back": "Common features match the spec, but some specified features are missing AND non-specified custom features were added."}, {"front": "Compliant", "back": "Some minor specified features are omitted, but every feature that was built IS in the spec and matches it."}, {"front": "Conformant", "back": "Every mandated feature is implemented correctly, but additional non-specified features also exist."}, {"front": "Fully Conformant", "back": "Absolute correspondence \u2014 every specified element built correctly, no non-specified elements exist."}, {"front": "Non-conformant", "back": "Some mandated features have been implemented in direct violation of the specification criteria."}]}, {"type": "knowledge_check", "question": "In an Architecture Compliance Review, who is responsible for formally verifying compliance against metrics?", "options": ["The auditor \u2014 the architect creates the impact assessment and recommendation", "The architect \u2014 they own the architecture and must pass or fail the project", "The project manager \u2014 they commissioned the work", "Both the architect and the auditor share equal responsibility"], "correct": 0, "explanation": "The AUDITOR verifies compliance against metrics. The ARCHITECT is the stakeholder's agent \u2014 responsible for creating a rigorous impact assessment and formal recommendation when non-compliance is found. The architect never 'passes or fails' a project; the auditor documents deviations."}]}, {"id": "states-security", "label": "\ud83d\uddc2\ufe0f States & Security", "blocks": [{"type": "dark_hero", "heading": "Architecture States \u00b7 Security \u00b7 Risk \u00b7 DPBoK", "subtext": "Track states across two dimensions: Time and Conformance", "badge": "High weight \u00b7 Both levels", "align": "center"}, {"type": "flashcard_deck", "accent": "#3b82f6", "label_front": "STATE", "label_back": "DEFINITION", "cards": [{"front": "Baseline / Current State", "back": "The architectural description of existing enterprise systems and processes currently in place."}, {"front": "Candidate State", "back": "A working hypothesis describing an unapproved transition or target state currently being explored by an active project."}, {"front": "Transition State", "back": "An approved intermediate architecture between Baseline and Target \u2014 a stable milestone where change can pause and deliver standalone value."}, {"front": "Target State", "back": "The approved future architecture state where the current defined time-horizon of architecture development ends."}, {"front": "Security \u2014 cross-cutting nature", "back": "Security is NOT a fifth layer. It actively cuts through and constrains all four domains simultaneously: Business \u00b7 Data \u00b7 Application \u00b7 Technology. Must be designed in from the start \u2014 not bolted on."}, {"front": "Risk \u2014 formal definition", "back": "The effect that uncertainty has on the achievement of business objectives. Analyzed top-down through the Business Stack: Value Chains \u2192 Capabilities \u2192 Processes \u2192 Services \u2192 Applications \u2192 ICT Infrastructure \u2192 Technical Components."}]}, {"type": "flashcard_deck", "accent": "#0ea5e9", "label_front": "DPBoK CONTEXT", "label_back": "ARCHITECTURE ROLE", "cards": [{"front": "Context I \u2014 Individual/Founder", "back": "Bare minimum for a single digital product. Architecture = communication medium for infrastructure availability."}, {"front": "Context II \u2014 Team", "back": "Collaborative product team. Architecture = maps digital product profiles to explicit interdependencies."}, {"front": "Context III \u2014 Team of Teams", "back": "High structural complexity. Architecture = depicts product portfolios, eliminates choke points."}, {"front": "Context IV \u2014 Enduring Enterprise", "back": "Long-term business management. Architecture = guides long-term information management through data and application domain frameworks."}]}]}]}, {"id": "stakeholders", "label": "\ud83e\udd1d Stakeholders", "color": "#10b981", "slides": [{"id": "concepts", "label": "\ud83d\udcda Concepts", "blocks": [{"type": "dark_hero", "heading": "Stakeholder Modeling Concepts", "subtext": "Six formal definitions \u2014 Part 1 tests recall, Part 2 tests application in scenarios", "badge": "High weight \u00b7 Foundation", "align": "center"}, {"type": "flashcard_deck", "accent": "#10b981", "label_front": "TERM", "label_back": "DEFINITION", "cards": [{"front": "Stakeholder", "back": "An individual or group possessing formal approval rights in the Target Architecture and subsequent decision rights regarding implementation suitability."}, {"front": "Concern", "back": "A consistent set of subjects that capture a stakeholder's absolute interests \u2014 consolidates technical requirements."}, {"front": "View", "back": "A specific representation of the architecture landscape structured to address a precise set of stakeholder concerns."}, {"front": "Viewpoint", "back": "The formal specification defining the concerns, specific stakeholders, construction method, and information needed to build a View."}, {"front": "Model