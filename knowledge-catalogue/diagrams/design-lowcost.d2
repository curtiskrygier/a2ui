direction: down

title: "A2UI Design Environment — Low Cost (Chromebook + Gemini App)" {
  near: top-center
  shape: text
  style.font-size: 18
  style.bold: true
  style.font-color: "#e2e8f0"
}

design: "Design Environment  ·  Chromebook" {
  style.fill: "#0f172a"
  style.stroke: "#334155"
  style.font-color: "#94a3b8"

  curtis: "Curtis\n(architect)" {
    shape: person
    style.fill: "#1e293b"
    style.font-color: "#e2e8f0"
    style.stroke: "#475569"
  }

  claude: "Claude Code\n(orchestrator · file ops · compiler)" {
    style.fill: "#7c3aed"
    style.font-color: white
    style.stroke: "#6d28d9"
  }

  gemini: "Gemini App\n(Prompt 0→1→2→3)" {
    style.fill: "#1a73e8"
    style.font-color: white
    style.stroke: "#1557b0"
  }

  curtis -> claude: "intent"
  curtis -> gemini: "brief + review"
  claude -> gemini: "feeds prompts\nreviews output"
}

catalogues: "Catalogues  ·  Laptop Filesystem" {
  style.fill: "#1e293b"
  style.stroke: "#475569"

  knowledge: "Knowledge Catalogue" {
    style.fill: "#0c4a6e"
    style.font-color: "#bae6fd"
    style.stroke: "#0369a1"
    k1: "schemas/  (competency specs)"
    k2: "*.curriculum.md  (extracted knowledge)"
    k3: "registry.yaml  (discovery index)"
  }

  ui: "UI Catalogue" {
    style.fill: "#312e81"
    style.font-color: "#c7d2fe"
    style.stroke: "#4338ca"
    u1: "atom types  (hub · flashcard · steps…)"
    u2: "payloads/  (compiled JSON)"
  }
}

gas: "GAS Runtime" {
  style.fill: "#14532d"
  style.font-color: "#bbf7d0"
  style.stroke: "#166534"
  renderer: "Hub Renderer  (atoms_*.gs)"
  deployed: "Deployed knowledge  (*_page.gs)"
}

source: "Source docs\n(PDF · official programme)" {
  shape: document
  style.fill: "#292524"
  style.font-color: "#d6d3d1"
  style.stroke: "#57534e"
}

source -> design.gemini: "Prompt 0+1\nextract + schema"
design.gemini -> catalogues.knowledge: "curriculum.md\nschema.yaml"
catalogues.knowledge -> design.gemini: "Prompt 2+3\nsuitability + transform"
design.gemini -> catalogues.ui: "payload.json"
design.claude -> catalogues: "file ops\norchestration"
catalogues.ui -> gas.deployed: "clasp push"
